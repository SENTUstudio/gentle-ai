{
  "agent": {
    "sdd-apply": {
      "description": "Implement code changes from task definitions",
      "hidden": true,
      "mode": "subagent",
      "prompt": "You are an SDD sub-agent for the apply phase. Your skill file is at ~/.config/opencode/skills/sdd-apply/SKILL.md — read it and follow its instructions.",
      "tools": {
        "bash": true,
        "edit": true,
        "read": true,
        "write": true
      }
    },
    "sdd-archive": {
      "description": "Archive completed change artifacts",
      "hidden": true,
      "mode": "subagent",
      "prompt": "You are an SDD sub-agent for the archive phase. Your skill file is at ~/.config/opencode/skills/sdd-archive/SKILL.md — read it and follow its instructions.",
      "tools": {
        "bash": true,
        "edit": true,
        "read": true,
        "write": true
      }
    },
    "sdd-design": {
      "description": "Create technical design from proposals",
      "hidden": true,
      "mode": "subagent",
      "prompt": "You are an SDD sub-agent for the design phase. Your skill file is at ~/.config/opencode/skills/sdd-design/SKILL.md — read it and follow its instructions.",
      "tools": {
        "bash": true,
        "edit": true,
        "read": true,
        "write": true
      }
    },
    "sdd-explore": {
      "description": "Investigate codebase and think through ideas",
      "hidden": true,
      "mode": "subagent",
      "prompt": "You are an SDD sub-agent for the explore phase. Your skill file is at ~/.config/opencode/skills/sdd-explore/SKILL.md — read it and follow its instructions.",
      "tools": {
        "bash": true,
        "edit": true,
        "read": true,
        "write": true
      }
    },
    "sdd-init": {
      "description": "Bootstrap SDD context and project configuration",
      "hidden": true,
      "mode": "subagent",
      "prompt": "You are an SDD sub-agent for the init phase. Your skill file is at ~/.config/opencode/skills/sdd-init/SKILL.md — read it and follow its instructions.",
      "tools": {
        "bash": true,
        "edit": true,
        "read": true,
        "write": true
      }
    },
    "sdd-orchestrator": {
      "description": "Agent Teams Orchestrator - coordinates sub-agents, never does work inline",
      "mode": "primary",
      "permission": {
        "task": {
          "*": "deny",
          "sdd-*": "allow"
        }
      },
      "prompt": "{file:./AGENTS.md}",
      "tools": {
        "bash": true,
        "edit": true,
        "read": true,
        "write": true
      }
    },
    "sdd-propose": {
      "description": "Create change proposals from explorations",
      "hidden": true,
      "mode": "subagent",
      "prompt": "You are an SDD sub-agent for the propose phase. Your skill file is at ~/.config/opencode/skills/sdd-propose/SKILL.md — read it and follow its instructions.",
      "tools": {
        "bash": true,
        "edit": true,
        "read": true,
        "write": true
      }
    },
    "sdd-spec": {
      "description": "Write detailed specifications from proposals",
      "hidden": true,
      "mode": "subagent",
      "prompt": "You are an SDD sub-agent for the spec phase. Your skill file is at ~/.config/opencode/skills/sdd-spec/SKILL.md — read it and follow its instructions.",
      "tools": {
        "bash": true,
        "edit": true,
        "read": true,
        "write": true
      }
    },
    "sdd-tasks": {
      "description": "Break down specs and designs into implementation tasks",
      "hidden": true,
      "mode": "subagent",
      "prompt": "You are an SDD sub-agent for the tasks phase. Your skill file is at ~/.config/opencode/skills/sdd-tasks/SKILL.md — read it and follow its instructions.",
      "tools": {
        "bash": true,
        "edit": true,
        "read": true,
        "write": true
      }
    },
    "sdd-verify": {
      "description": "Validate implementation against specs",
      "hidden": true,
      "mode": "subagent",
      "prompt": "You are an SDD sub-agent for the verify phase. Your skill file is at ~/.config/opencode/skills/sdd-verify/SKILL.md — read it and follow its instructions.",
      "tools": {
        "bash": true,
        "edit": true,
        "read": true,
        "write": true
      }
    }
  }
